{
  "training_algorithm": "ppo",
  "adapter_mode": "qlora",
  "base_model_load_mode": "4bit",
  "compute_dtype": "bfloat16",
  "reward_function": "structured_json_accuracy_with_hallucination_penalty",
  "ppo": {
    "batch_size": 1,
    "mini_batch_size": 1,
    "gradient_accumulation_steps": 1,
    "learning_rate": 1e-05,
    "ppo_epochs": 2,
    "init_kl_coef": 0.2,
    "max_prompt_length": 256,
    "max_new_tokens": 24,
    "temperature": 0.7,
    "top_p": 0.95
  }
}